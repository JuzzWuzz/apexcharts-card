{
  "name": "apexcharts-card",
  "version": "1.2.1",
  "description": "A Home Assistant Lovelace card using ApexCharts to render graphs",
  "main": "src/apexcharts-card.ts",
  "type": "module",
  "scripts": {
    "build": "npm run build:clean && npm run build:check && npm run lint && rollup -c rollup.config.js",
    "build:clean": "rimraf dist",
    "build:check": "ts-interface-builder src/types-config.ts",
    "lint": "eslint --fix src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "start": "rollup -c rollup.config.js --watch"
  },
  "keywords": [
    "lovelace",
    "apexcharts",
    "graphs",
    "charts",
    "home-assistant"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ctrl/tinycolor": "^4.1.0",
    "@material/mwc-ripple": "^0.27.0",
    "@mdi/js": "^7.4.47",
    "apexcharts": "^5.3.3",
    "lit": "^3.1.4",
    "luxon": "^3.5.0",
    "ts-interface-checker": "^1.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/luxon": "^3.4.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "home-assistant-js-websocket": "^9.4.0",
    "juzz-ha-helper": "file:../juzz-ha-helper",
    "prettier": "^3.3.2",
    "prettier-eslint": "^16.4.2",
    "prettier-plugin-multiline-arrays": "^4.1.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.18.0",
    "rollup-plugin-serve": "^3.0.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-interface-builder": "^0.3.3",
    "typescript": "^5.4.5"
  }
}
